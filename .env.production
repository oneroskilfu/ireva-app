# iREVA Platform - Production Environment Variables
# These are used in production deployments (Render.com, etc.)

# Application
NODE_ENV=production
PORT=10000

# Database (will be automatically set by Render.com)
# DATABASE_URL=postgresql://user:password@host:port/database

# Authentication
# JWT_SECRET=<auto-generated-by-render>

# Redis (optional for production)
REDIS_GRACEFUL_FALLBACK=true
# REDIS_URL=<redis-connection-string>

# External Services (set in Render dashboard)
# STRIPE_SECRET_KEY=<your-stripe-secret-key>
# OPENAI_API_KEY=<your-openai-api-key>

# Firebase (for push notifications)
VITE_FIREBASE_API_KEY=AIzaSyAHhiM0PxwYn8a64DzOBco5RWlXf4adQOk
VITE_FIREBASE_AUTH_DOMAIN=ireva-platform.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ireva-platform
VITE_FIREBASE_STORAGE_BUCKET=ireva-platform.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=488160387734
VITE_FIREBASE_APP_ID=1:488160387734:web:02088d5591c8d75f4598b7
VITE_FIREBASE_MEASUREMENT_ID=G-LHGPCTYFTK

# Performance
MINIMAL_STARTUP=true
DB_INITIALIZATION_MODE=production